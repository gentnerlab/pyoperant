#!/bin/sh
# DEPRECATED: pyoperantctl (the legacy Perl process controller) has been retired.
#
# It only ever worked on the old single-machine / numeric-box layout: it acted
# on LOCAL processes (it never used SSH) and required column 1 of
# panel_subject_behavior to be a numeric box number in the range 1-16. The
# current fleet uses hostnames (e.g. magpi03) in that column and is orchestrated
# from the MagPi server over SSH, so this tool can no longer act on the live
# config at all -- it would ignore every row.
#
# Use rpioperantctl instead (runs on the MagPi server, reconciling every box
# against panel_subject_behavior):
#
#   /home/bird/code/rpioperantctl/rpioperantctl.py        # dry run (no changes)
#   /home/bird/code/rpioperantctl/rpioperantctl.py -s     # start what should run
#   /home/bird/code/rpioperantctl/rpioperantctl.py -k     # kill what shouldn't
#
# Always edit /home/bird/opdat/panel_subject_behavior first and let
# rpioperantctl reconcile. See pyoperant_manual.md sections 5.2 and 7.

echo "pyoperantctl is deprecated and no longer functional against the current setup." >&2
echo "Use rpioperantctl on the MagPi server instead (see pyoperant_manual.md sections 5.2 and 7)." >&2
exit 1
